# Authoritative style config for the repository (see CLAUDE.md).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{cs,csproj,props,targets,sln}]
indent_size = 4

[*.cs]
# Naming and style follow Microsoft's C# Coding Conventions.
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_prefer_switch_expression = true:suggestion
csharp_prefer_braces = true:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
dotnet_style_readonly_field = true:warning
dotnet_sort_system_directives_first = true

# Private instance fields: _camelCase
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.capitalization = camel_case
dotnet_naming_style.underscore_camel.required_prefix = _

# Interfaces: IPascalCase
dotnet_naming_rule.interfaces_prefixed.severity = warning
dotnet_naming_rule.interfaces_prefixed.symbols = interfaces
dotnet_naming_rule.interfaces_prefixed.style = prefix_i
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_style.prefix_i.capitalization = pascal_case
dotnet_naming_style.prefix_i.required_prefix = I

# Async methods end in Async
dotnet_naming_rule.async_suffix.severity = suggestion
dotnet_naming_rule.async_suffix.symbols = async_methods
dotnet_naming_rule.async_suffix.style = async_style
dotnet_naming_symbols.async_methods.applicable_kinds = method
dotnet_naming_symbols.async_methods.required_modifiers = async
dotnet_naming_style.async_style.capitalization = pascal_case
dotnet_naming_style.async_style.required_suffix = Async

[*.md]
trim_trailing_whitespace = false
